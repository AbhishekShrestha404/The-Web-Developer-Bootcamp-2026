<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product</title>
</head>

<body>
    <h1>Please fill up the form.</h1>
    <form action="/products/<%= product._id%>?_method=PUT" method="POST">
        <label for="name">Product Name:</label>
        <input type="text" name="name" id="name" placeholder="Enter product name." value="<%= product.name %>"><br>

        <label for="price">Price:</label>
        <input type="number" name="price" id="price" value="<%= product.price %>"><br>

        <label for="category">Select Category:</label>
        <select name="category" id="category">
            <option value="fruit" <%=product.category==='fruit' ? 'selected' :'' %>>
                Fruit</option>
            <option value="vegetable" <%=product.category==='vegetable' ? 'selected' :''%>>
                Vegetable</option>
            <option value="dairy" <%=product.category==='dairy' ? 'selected' :''%>>
                Dairy</option>
        </select><br>
        <button type="submit">Submit</button>
    </form>

    <a href="/products/<%= product._id %>">Cancel</a>
</body>

</html>